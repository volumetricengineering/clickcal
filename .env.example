# Copy to .env and fill in. All vars are prefixed CLICKCAL_.

# Required: ClickUp personal access token (Settings -> Apps -> API Token).
CLICKCAL_TOKEN=pk_0000000_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Required: the ClickUp space whose tasks you want to export.
CLICKCAL_SPACE_ID=90010000000

# Optional: comma-separated list IDs or names to exclude from the feed.
# Names match case-insensitively.
CLICKCAL_EXCLUDED_LISTS=Backlog,Someday

# Optional: include closed/done tasks (default false).
CLICKCAL_INCLUDE_CLOSED=false

# Optional: include subtasks (default true).
CLICKCAL_INCLUDE_SUBTASKS=true

# Optional: calendar display name (default "ClickUp").
CLICKCAL_CALENDAR_NAME=ClickUp

# Optional: IANA timezone of your ClickUp workspace (default UTC). Used to
# render timed events in the right zone and to classify same-day tasks.
CLICKCAL_TIMEZONE=UTC

# Optional: how long (seconds) to reuse a rendered feed before refetching from
# ClickUp (default 300). Set to 0 to disable caching.
CLICKCAL_CACHE_TTL=300

# Optional: secret that makes the feed URL private. When set, the feed is served
# at /calendar/<token>.ics and /calendar.ics returns 404. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Always serve over HTTPS, since the URL itself is the credential.
# CLICKCAL_FEED_TOKEN=

# Optional: HTTP host/port for the server (defaults 0.0.0.0:8000).
CLICKCAL_HOST=0.0.0.0
CLICKCAL_PORT=8000
